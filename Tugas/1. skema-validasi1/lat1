Program JAM
{Mengecekan kevalidan jam}

KAMUS
    { Definisi Type }
    type jam : < HH : integer,  { bagian jam }
                 MM : integer,  { bagian menit }
                 SS : integer > { bagian detik }
    { Definisi Variabel }
    J : jam
    h, m, s : integer

ALGORITMA
    input(h, m, s)
    if h >= 0 and h <= 23 and m >= 0 and m <= 59 and s >= 0 and s <= 59 then
        J.HH <- h
        J.MM <- m
        J.SS <- s
    else { Nilai tidak valid }
        output("Tidak dapat membentuk jam")
